# ─────────────────────────────────────────────────────────────
# .env.example  –  Copy to .env and fill in your real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Email (optional – set EMAIL_ENABLED=true to send reports) ─
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password_here     # Google: myaccount.google.com/apppasswords
EMAIL_FROM=you@gmail.com
EMAIL_TO=recipient1@example.com,recipient2@example.com

# ── Advanced summarization (optional – needs torch + transformers) ─
USE_TRANSFORMER_SUMMARY=false

# ── Dashboard port ─────────────────────────────────────────────
DASHBOARD_PORT=8501
